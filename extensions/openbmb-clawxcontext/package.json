{
  "name": "openbmb-clawxcontext",
  "version": "0.1.0",
  "description": "OpenClaw context-engine plugin focused on Claude Code-style context management.",
  "keywords": [
    "openclaw",
    "plugin",
    "context",
    "context-engine",
    "ai-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenBMB/ClawXContext.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/OpenBMB/ClawXContext/issues"
  },
  "homepage": "https://github.com/OpenBMB/ClawXContext#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "openclaw.plugin.json",
    "LICENSE"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -b --force",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false",
    "relink": "node ../dev-scripts/clawxcontext-relink.mjs",
    "reload": "node ../dev-scripts/clawxcontext-reload.mjs",
    "uninstall": "node ../dev-scripts/clawxcontext-uninstall.mjs",
    "lint": "node -e \"console.log('lint skipped for plugin')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "devDependencies": {
    "openclaw": "^2026.3.28",
    "typescript": "^5.8.3",
    "vitest": "^4.0.5"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.22",
      "minGatewayVersion": "2026.3.22"
    },
    "build": {
      "openclawVersion": "2026.3.28"
    }
  }
}
